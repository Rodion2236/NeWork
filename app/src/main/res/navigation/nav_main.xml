<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="ru.netology.nework.fragments.main.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main" >
        <action
            android:id="@+id/action_mainFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="ru.netology.nework.fragments.auth.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="ru.netology.nework.fragments.auth.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register" />
    <fragment
        android:id="@+id/eventsFragment"
        android:name="ru.netology.nework.fragments.item.EventsFragment"
        android:label="fragment_events"
        tools:layout="@layout/fragment_event" />
    <fragment
        android:id="@+id/detailPostFragment"
        android:name="ru.netology.nework.fragments.detailItem.DetailPostFragment"
        android:label="fragment_detail_post"
        tools:layout="@layout/fragment_detail_post" >
        <argument
            android:name="postId"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/detailEventFragment"
        android:name="ru.netology.nework.fragments.detailItem.DetailEventFragment"
        android:label="fragment_detail_event"
        tools:layout="@layout/fragment_detail_event" >
        <argument
            android:name="eventId"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/detailUserFragment"
        android:name="ru.netology.nework.fragments.detailItem.DetailUserFragment"
        android:label="fragment_detail_user"
        tools:layout="@layout/fragment_detail_user" >
        <argument
            android:name="userId"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/newPostFragment"
        android:name="ru.netology.nework.fragments.newItem.NewPostFragment"
        android:label="fragment_new_post"
        tools:layout="@layout/fragment_new_post" >
        <argument
            android:name="postId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="isEditMode"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>
    <fragment
        android:id="@+id/newEventFragment"
        android:name="ru.netology.nework.fragments.newItem.NewEventFragment"
        android:label="fragment_new_event"
        tools:layout="@layout/fragment_new_event" >
        <argument
            android:name="eventId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="isEditMode"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_newEventFragment_to_eventsFragment"
            app:destination="@id/eventsFragment"
            app:popUpTo="@id/eventsFragment"
            app:popUpToInclusive="false"
            app:launchSingleTop="true" />
    </fragment>
    <fragment
        android:id="@+id/newJobFragment"
        android:name="ru.netology.nework.fragments.newItem.NewJobFragment"
        android:label="fragment_new_job"
        tools:layout="@layout/fragment_new_job" />
    <fragment
        android:id="@+id/mapsFragment"
        android:name="ru.netology.nework.fragments.item.MapsFragment"
        android:label="fragment_maps"
        tools:layout="@layout/fragment_maps" />
    <fragment
        android:id="@+id/jobsFragment"
        android:name="ru.netology.nework.fragments.item.JobsFragment"
        android:label="fragment_jobs"
        tools:layout="@layout/fragment_jobs" />
    <action
        android:id="@+id/action_global_to_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/mainFragment"
        app:popUpToInclusive="false" />
    <action
        android:id="@+id/action_global_to_detailPostFragment"
        app:destination="@id/detailPostFragment" />

    <action
        android:id="@+id/action_global_to_detailEventFragment"
        app:destination="@id/detailEventFragment" />

    <action
        android:id="@+id/action_global_to_detailUserFragment"
        app:destination="@id/detailUserFragment" />

    <action
        android:id="@+id/action_global_to_mapsFragment"
        app:destination="@id/mapsFragment" />
    <action
        android:id="@+id/action_global_to_eventsFragment"
        app:destination="@id/eventsFragment"
        app:popUpTo="@id/mainFragment"
        app:popUpToInclusive="false" />
</navigation>